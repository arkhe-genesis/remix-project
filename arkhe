import argparse
import json
import urllib.request
import urllib.error
import sys
import subprocess


def vyupgrade(path, target_version=None, zk_proof=False, anchor=None, glasswing=False, check=False, report_json=None):
    print(f"Iniciando ARKHE Vyper Evolution Engine (Substrato 945)...")
    print(f"Alvo: {path}")
    if check:
        print("Modo: Check-only (CI/CD Pipeline)")
    else:
        print("Modo: Rewrite")
    if target_version:
        print(f"Versão alvo: {target_version}")

    if glasswing:
        print("Executando varredura Glasswing Sentinel (Substrato 944)...")
        # In a real scenario, we would call glasswing_sentinel.py here
        try:
            subprocess.run(["python3", "glasswing_sentinel.py", "scan", path], check=True)
        except Exception as e:
            print(f"Aviso: Glasswing Sentinel falhou ou não está disponível: {e}")

    # Mock da chamada real do vyupgrade
    cmd = ["vyupgrade", path]
    if check:
        cmd.append("--check")
    if report_json:
        cmd.extend(["--report-json", report_json])
    if target_version:
        cmd.extend(["--target-version", target_version])

    print(f"Comando simulado: {' '.join(cmd)}")

    if zk_proof:
        print("Gerando prova ZK de equivalência comportamental (Substrato 255)...")

    if anchor:
        print(f"Ancorando hash de upgrade + prova na TemporalChain ({anchor})...")

    print("Operação concluída.")

def chat(endpoint: str, model: str = "arkhe-os"):
    print(f"Iniciando ARKHE Chat...")
    print(f"Conectando ao servidor: {endpoint}")
    print("Digite 'sair' ou 'exit' para encerrar.\n")

    messages = [
        {"role": "system", "content": "Você é o ARKHE-OS, um assistente de IA extremamente capaz. Ajude o usuário de forma concisa e precisa."}
    ]

    while True:
        try:
            user_input = input("\033[92mVocê:\033[0m ")
            if user_input.strip().lower() in ['sair', 'exit', 'quit']:
                print("Encerrando a conexão com ARKHE-OS.")
                break

            if not user_input.strip():
                continue

            messages.append({"role": "user", "content": user_input})

            data = {
                "model": model,
                "messages": messages,
                "stream": False,
                "temperature": 0.7
            }

            req = urllib.request.Request(
                f"{endpoint}/v1/chat/completions",
                data=json.dumps(data).encode('utf-8'),
                headers={'Content-Type': 'application/json'}
            )

            print("\033[94mARKHE-OS:\033[0m ", end="", flush=True)

            try:
                with urllib.request.urlopen(req) as response:
                    result = json.loads(response.read().decode('utf-8'))
                    response_text = result['choices'][0]['message']['content']
                    print(response_text)
                    messages.append({"role": "assistant", "content": response_text})
            except urllib.error.URLError as e:
                print(f"\n[Erro de Conexão] Falha ao comunicar com o servidor: {e}")
                print("Certifique-se de que o servidor llama.cpp está rodando.")
                messages.pop() # Remove a mensagem do usuário se a request falhar

            print() # Nova linha após a resposta

        except KeyboardInterrupt:
            print("\nEncerrando a conexão com ARKHE-OS.")
            break
        except EOFError:
            print("\nEncerrando a conexão com ARKHE-OS.")
            break

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="ARKHE CLI - Interação com ARKHE-OS")
    subparsers = parser.add_subparsers(dest="command", help="Comandos disponíveis")

    chat_parser = subparsers.add_parser("chat", help="Inicia um chat interativo com o modelo")
    chat_parser.add_argument("--endpoint", default="http://localhost:8080", help="URL do servidor llama.cpp (padrão: http://localhost:8080)")
    chat_parser.add_argument("--model", default="arkhe-os", help="Nome do modelo (padrão: arkhe-os)")


    vyupgrade_parser = subparsers.add_parser("vyupgrade", help="Motor de evolução segura de contratos Vyper (vyupgrade)")
    vyupgrade_parser.add_argument("path", help="Caminho para os contratos Vyper")
    vyupgrade_parser.add_argument("--target-version", help="Versão alvo do compilador")
    vyupgrade_parser.add_argument("--zk-proof", action="store_true", help="Gerar prova ZK de equivalência")
    vyupgrade_parser.add_argument("--anchor", help="Ancorar na TemporalChain (ex: 923.2)")
    vyupgrade_parser.add_argument("--glasswing", action="store_true", help="Executar scan de vulnerabilidades (944)")
    vyupgrade_parser.add_argument("--check", action="store_true", help="Verificar se há mudanças necessárias sem escrever")
    vyupgrade_parser.add_argument("--report-json", help="Caminho para o relatório JSON")


    hotspots_parser = subparsers.add_parser("hotspots", help="Analyze interaction hotspots in MD trajectory (Substrato 949).")
    hotspots_parser.add_argument("trajectory", help="Path to MD trajectory")
    hotspots_parser.add_argument("topology", help="Path to topology file")
    hotspots_parser.add_argument("--system-name", default="unknown", help="System name")
    hotspots_parser.add_argument("--no-anchor", action="store_true", help="Do not anchor results on TemporalChain")

    hermes_bridge_parser = subparsers.add_parser("hermes-bridge", help="Hermes-Cathedral Bridge (Substrato 1040)")
    hermes_bridge_parser.add_argument("--demo", action="store_true", help="Executar demonstração de ingestão e sincronização")
    args = parser.parse_args()

    if args.command == "chat":
        chat(args.endpoint, args.model)
    elif args.command == "vyupgrade":
        vyupgrade(
            args.path,
            target_version=args.target_version,
            zk_proof=args.zk_proof,
            anchor=args.anchor,
            glasswing=args.glasswing,
            check=args.check,
            report_json=args.report_json
        )
    elif args.command == "hotspots":
        import asyncio
        import sys

        # Provide a mock or import fallback if needed to avoid ModuleNotFoundError when missing dependencies like numpy
        try:
            from arkhe_sdk.substrates.interaction_hotspots import InteractionHotspotsAnalyzer

            async def _run_hotspots():
                analyzer = InteractionHotspotsAnalyzer()
                result = await analyzer.analyze_trajectory(
                    args.trajectory, args.topology, args.system_name, not args.no_anchor
                )
                print("Analysis complete")
                print(f"  Mean log10 deviation: {result.mean_log_deviation:.3f}")
                print(f"  Anisotropy index: {result.anisotropy_index:.3f}")
                print(f"  Hotspot residue pairs: {len(result.residue_pairs)}")

            asyncio.run(_run_hotspots())
        except ImportError as e:
            print(f"Substrate 949 Error: {e}")
            print("Make sure requirements are installed (e.g., numpy, httpx).")
            sys.exit(1)
    elif args.command == "hermes-bridge":
        try:
            from arkhe_sdk.substrates.hermes_bridge_1040 import HermesCathedralBridge, MANIFESTO_1040
            import time
            print(MANIFESTO_1040)
            bridge = HermesCathedralBridge()
            if args.demo:
                bridge.ingest_skill({"id": "web-search", "name": "Web Search", "code": "def search(query): ...", "usage_count": 150, "success_rate": 0.92})
                bridge.ingest_memory({"id": "mem-001", "content": "User prefers dark mode", "session_id": "sess-001", "timestamp": time.time(), "platform": "telegram", "access_count": 5})
                bridge.ingest_gateway({"id": "gw-telegram-001", "platform": "telegram", "token": "bot123456:ABC-DEF...", "users": ["user1", "user2", "user3"], "messages": 1250})
                bridge.ingest_cron({"id": "cron-daily", "schedule": "0 9 * * *", "command": "send_daily_report()", "platform": "email"})
                bridge.ingest_subagent({"id": "agent-research", "task": "Research quantum computing advances", "status": "running", "session": "sess-001", "tools": ["web_search", "arxiv_api", "summarize"]})
                bridge.sync_to_cathedral()
                bridge.run_health_check()
            status = bridge.status()
            import json
            print("\n[1040] Status Atual:")
            print(json.dumps(status, indent=2))
        except ImportError as e:
            print(f"Substrate 1040 Error: {e}")
            print("Make sure requirements are installed (e.g., numpy).")
    else:
        parser.print_help()
