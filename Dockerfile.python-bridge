FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates curl python3 python3-pip && rm -rf /var/lib/apt/lists/*

# Instalar dependências Python para bridge
RUN pip3 install --no-cache-dir httpx pydantic

WORKDIR /app
COPY cathedral_agent_bridge.py /opt/cathedral/

EXPOSE 8001
CMD ["python3", "/opt/cathedral/cathedral_agent_bridge.py"]